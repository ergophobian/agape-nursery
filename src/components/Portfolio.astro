---
import { portfolio, portfolioFilters } from '../content/site';
---

<section id="portfolio" class="portfolio" aria-labelledby="portfolio-h2">
  <div class="container">
    <header class="portfolio-head reveal" data-anim="reveal">
      <span class="eyebrow">Our Work · <span lang="es">Nuestro Trabajo</span></span>
      <h2 id="portfolio-h2">Yards we’re proud of.</h2>
      <p class="lang-es lead-es" lang="es">Jardines que nos llenan de orgullo.</p>
    </header>

    <div class="filter-bar reveal" data-anim="reveal" role="tablist" aria-label="Filter portfolio">
      {portfolioFilters.map((f, i) => (
        <button
          type="button"
          class="filter-chip"
          data-filter={f.id}
          aria-selected={i === 0 ? 'true' : 'false'}
          role="tab"
        >
          {f.en}
          <span class="filter-chip-es" lang="es">{f.es}</span>
        </button>
      ))}
    </div>

    <ul class="masonry reveal-stagger" role="list" data-anim="reveal-stagger" data-portfolio>
      {portfolio.map((p, i) => (
        <li class={`portfolio-item portfolio-item--${(i % 6) + 1}`} data-tags={p.tags.join(' ')}>
          <a href="#contact" class="portfolio-link" aria-label={`Get a quote for a project like ${p.title.en}`}>
            <div class="portfolio-frame">
              <img
                src={p.image}
                alt={p.title.en}
                loading="lazy"
                decoding="async"
                width="800"
                height="800"
              />
              <span class="portfolio-overlay" aria-hidden="true"></span>
              <span class="portfolio-tag">Placeholder · Drive coming</span>
            </div>
            <div class="portfolio-meta">
              <h3 class="portfolio-title">{p.title.en}</h3>
              <p class="portfolio-title-es lang-es" lang="es">{p.title.es}</p>
              <p class="portfolio-loc">{p.location}</p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<script>
  // Lightweight filter — toggles `data-tags` match against active chip.
  // Lightbox is deferred to v2 (PLAN.md §7 file structure includes lightbox.ts
  // with focus-trap + body-scroll-lock libs; v0 ships with click-through to contact).
  const chips = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
  const items = document.querySelectorAll<HTMLElement>('[data-portfolio] [data-tags]');

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      chips.forEach((c) => c.setAttribute('aria-selected', 'false'));
      chip.setAttribute('aria-selected', 'true');
      const filter = chip.dataset.filter;
      items.forEach((item) => {
        if (filter === 'all' || (item.dataset.tags || '').includes(filter || '')) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  .portfolio {
    background: var(--cream);
    border-top: 1px solid var(--soil-brown-15);
  }

  .portfolio-head {
    max-width: 36rem;
    margin-bottom: 1.5rem;
  }
  .portfolio-head h2 {
    margin-top: 0.4rem;
  }
  .lead-es { font-size: 1rem; color: var(--soil-brown-60); margin-top: 0.25rem; }

  /* Filter bar */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }
  .filter-chip {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 0.5rem 0.95rem;
    border-radius: var(--rad-pill);
    background: transparent;
    border: 1px solid var(--soil-brown-15);
    color: var(--soil-brown);
    font-size: 0.92rem;
    font-weight: 500;
    cursor: pointer;
    transition: all var(--dur-fast) var(--ease-out-soft);
    line-height: 1.15;
  }
  .filter-chip-es {
    font-size: 0.7rem;
    color: var(--soil-brown-60);
    font-style: italic;
  }
  .filter-chip:hover {
    border-color: var(--olive-deep);
    color: var(--olive-deep);
  }
  .filter-chip[aria-selected='true'] {
    background: var(--olive-deep);
    color: var(--cream);
    border-color: var(--olive-deep);
  }
  .filter-chip[aria-selected='true'] .filter-chip-es {
    color: rgba(245, 239, 227, 0.7);
  }

  /* Masonry — CSS grid with explicit row spans for visual rhythm */
  .masonry {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    grid-auto-rows: 1fr;
  }
  @media (min-width: 40rem) {
    .masonry {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 200px;
    }
    .portfolio-item--1 { grid-row: span 2; }
    .portfolio-item--4 { grid-row: span 2; }
  }
  @media (min-width: 64rem) {
    .masonry {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: 220px;
    }
    .portfolio-item--1 { grid-row: span 2; }
    .portfolio-item--4 { grid-row: span 2; }
    .portfolio-item--6 { grid-row: span 1; }
  }

  .portfolio-item {
    position: relative;
    border-radius: var(--rad-lg);
    overflow: hidden;
  }

  .portfolio-link {
    display: block;
    height: 100%;
    position: relative;
    overflow: hidden;
    border-radius: var(--rad-lg);
  }

  .portfolio-frame {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 200px;
    overflow: hidden;
  }
  .portfolio-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-slow) var(--ease-out-soft);
  }
  .portfolio-link:hover .portfolio-frame img {
    transform: scale(1.04);
  }

  .portfolio-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(62, 46, 32, 0) 50%,
      rgba(62, 46, 32, 0.7) 100%
    );
    pointer-events: none;
  }

  .portfolio-tag {
    position: absolute;
    top: 0.65rem;
    left: 0.65rem;
    background: rgba(245, 239, 227, 0.92);
    color: var(--soil-brown);
    font-size: 0.7rem;
    padding: 0.25rem 0.6rem;
    border-radius: var(--rad-pill);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  .portfolio-meta {
    position: absolute;
    left: 1rem;
    right: 1rem;
    bottom: 0.85rem;
    color: var(--cream);
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.35);
  }
  .portfolio-title {
    color: var(--cream);
    font-size: 1.18rem;
    line-height: 1.2;
    font-family: var(--font-display);
    font-weight: 700;
  }
  .portfolio-title-es {
    color: rgba(245, 239, 227, 0.8);
    font-size: 0.85rem;
    margin-top: 0.1rem;
  }
  .portfolio-loc {
    font-size: 0.78rem;
    color: rgba(245, 239, 227, 0.8);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 0.25rem;
  }
</style>
