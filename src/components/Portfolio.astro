---
import { portfolio, portfolioFilters } from '../content/site';
---

<section id="portfolio" class="portfolio" aria-labelledby="portfolio-h2">
  <div class="container portfolio-inner">
    <header class="portfolio-head reveal" data-anim="reveal">
      <div class="portfolio-head-text">
        <span class="eyebrow">
          <span data-lang-en>Our Work</span><span data-lang-es>Nuestro Trabajo</span>
        </span>
        <h2 id="portfolio-h2" class="portfolio-h2">
          <span data-lang-en>Yards <span class="italic-display accent">we’re proud</span> of.</span>
          <span data-lang-es>Jardines <span class="italic-display accent">de los que</span> estamos orgullosos.</span>
        </h2>
      </div>
      <p class="portfolio-meta">
        <span class="portfolio-meta-num italic-display">200+</span>
        <span class="portfolio-meta-label">
          <span data-lang-en>installs across<br />Tulare + Kern</span>
          <span data-lang-es>instalaciones en<br />Tulare + Kern</span>
        </span>
      </p>
    </header>

    <div class="filter-bar reveal" data-anim="reveal" role="tablist" aria-label="Filter portfolio">
      {portfolioFilters.map((f, i) => (
        <button
          type="button"
          class="filter-chip"
          data-filter={f.id}
          aria-selected={i === 0 ? 'true' : 'false'}
          role="tab"
        >
          <span data-lang-en>{f.en}</span><span data-lang-es>{f.es}</span>
        </button>
      ))}
    </div>

    <!-- Asymmetric editorial grid: large feature + smaller items -->
    <ul class="portfolio-grid reveal-stagger" role="list" data-anim="reveal-stagger" data-portfolio>
      {portfolio.map((p, i) => (
        <li class={`portfolio-item portfolio-item--${i}`} data-tags={p.tags.join(' ')} data-tilt data-tilt-intensity="6">
          <a href="#contact" class="portfolio-link" aria-label={`Get a quote for a project like ${p.title.en}`}>
            <div class="portfolio-frame">
              <img src={p.image} alt={p.title.en} loading="lazy" decoding="async" width="1200" height="900" />
              <div class="portfolio-overlay"></div>
              <span class="portfolio-sheen" data-tilt-sheen aria-hidden="true"></span>
              <div class="portfolio-meta-tag">
                <span class="meta-year italic-display">{p.year}</span>
              </div>
            </div>
            <div class="portfolio-info">
              <h3 class="portfolio-title">
                <span data-lang-en>{p.title.en}</span><span data-lang-es>{p.title.es}</span>
              </h3>
              <p class="portfolio-loc">
                <span class="loc-dot" aria-hidden="true"></span>
                <span>{p.location}</span>
              </p>
            </div>
            <span class="portfolio-cta">
              <span class="portfolio-cta-text">
                <span data-lang-en>See more</span><span data-lang-es>Ver más</span>
              </span>
              <span aria-hidden="true">→</span>
            </span>
          </a>
        </li>
      ))}
    </ul>

    <div class="portfolio-bottom reveal" data-anim="reveal">
      <p class="portfolio-bottom-text">
        <span data-lang-en>Like what you see? Your yard can look like this too.</span>
        <span data-lang-es>¿Le gusta lo que ve? Su patio también puede verse así.</span>
      </p>
      <a href="#booking" class="btn btn-primary">
        <span data-lang-en>Book a Free Consultation</span><span data-lang-es>Reservar Consulta Gratis</span>
        <span class="btn-arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
  const items = document.querySelectorAll<HTMLElement>('[data-portfolio] [data-tags]');

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      chips.forEach((c) => c.setAttribute('aria-selected', 'false'));
      chip.setAttribute('aria-selected', 'true');
      const filter = chip.dataset.filter;
      items.forEach((item) => {
        if (filter === 'all' || (item.dataset.tags || '').includes(filter || '')) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  .portfolio {
    background: var(--cream);
    position: relative;
    overflow: hidden;
  }

  .portfolio-inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .portfolio-head {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .portfolio-head-text {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .portfolio-h2 {
    font-size: clamp(2rem, 5vw, 3.8rem);
    line-height: 1.02;
    max-width: 16ch;
  }
  .portfolio-h2 .accent {
    color: var(--terracotta);
  }

  .portfolio-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    align-self: flex-start;
    padding: 0.5rem 1rem 0.5rem 0.5rem;
    background: rgba(74, 93, 58, 0.08);
    border-radius: var(--rad-pill);
  }
  .portfolio-meta-num {
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--terracotta);
    letter-spacing: -0.04em;
    line-height: 1;
    padding-left: 0.4rem;
  }
  .portfolio-meta-label {
    font-size: 0.78rem;
    color: var(--soil-brown-75);
    line-height: 1.2;
    font-weight: 500;
  }

  /* Filter chips */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }
  .filter-chip {
    padding: 0.45rem 0.95rem;
    border-radius: var(--rad-pill);
    background: transparent;
    border: 1px solid var(--soil-brown-15);
    color: var(--soil-brown);
    font-size: 0.88rem;
    font-weight: 500;
    cursor: pointer;
    transition: all var(--dur-fast) var(--ease-out-soft);
  }
  .filter-chip:hover {
    border-color: var(--olive-deep);
    color: var(--olive-deep);
  }
  .filter-chip[aria-selected='true'] {
    background: var(--olive-deep);
    color: var(--cream);
    border-color: var(--olive-deep);
  }

  /* Mobile: clean 1-col stack — no grid-row overrides at this size.
     The asymmetric editorial layout kicks in at 48rem+. */
  .portfolio-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
  }
  .portfolio-grid .portfolio-frame {
    aspect-ratio: 4 / 3;
  }

  .portfolio-item {
    position: relative;
    will-change: transform;
    transition: transform var(--dur-base) var(--ease-out-soft);
    transform-style: preserve-3d;
  }

  .portfolio-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    border-radius: var(--rad-lg);
    overflow: hidden;
    background: var(--cream);
    transition: box-shadow var(--dur-base) var(--ease-out-soft);
  }
  .portfolio-item:hover .portfolio-link {
    box-shadow:
      0 30px 60px var(--shadow-warm-elev),
      0 8px 20px var(--shadow-warm);
  }

  /* Sheen — moves with cursor on tilt */
  .portfolio-sheen {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity var(--dur-fast) var(--ease-out-soft);
    z-index: 2;
    mix-blend-mode: overlay;
  }

  .portfolio-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }
  .portfolio-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s var(--ease-out-quint), filter var(--dur-base) var(--ease-out-soft);
    filter: saturate(1.04);
  }
  .portfolio-link:hover .portfolio-frame img {
    transform: scale(1.06);
    filter: saturate(1.12) contrast(1.04);
  }

  .portfolio-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 60%, rgba(31, 23, 14, 0.4) 100%);
    pointer-events: none;
  }

  .portfolio-meta-tag {
    position: absolute;
    top: 0.75rem;
    left: 0.85rem;
    background: rgba(245, 239, 227, 0.9);
    backdrop-filter: blur(6px);
    padding: 0.3rem 0.7rem;
    border-radius: var(--rad-pill);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--olive-deep);
  }
  .meta-year {
    font-style: italic;
    letter-spacing: -0.02em;
  }

  .portfolio-info {
    padding: 1rem 1.1rem 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
  }
  .portfolio-title {
    font-size: 1.15rem;
    color: var(--olive-deep);
    line-height: 1.2;
    font-weight: 700;
  }
  .portfolio-loc {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    color: var(--soil-brown-60);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .loc-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--terracotta);
  }

  .portfolio-cta {
    padding: 0.75rem 1.1rem 1.1rem;
    color: var(--terracotta);
    font-size: 0.85rem;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: gap var(--dur-fast) var(--ease-out-soft);
  }
  .portfolio-link:hover .portfolio-cta {
    gap: 0.6rem;
  }

  .portfolio-bottom {
    margin-top: 1.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--soil-brown-15);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    text-align: center;
  }
  .portfolio-bottom-text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    color: var(--olive-deep);
    max-width: 28ch;
  }

  @media (min-width: 48rem) {
    .portfolio-head {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
      gap: 2rem;
    }
    .portfolio-grid {
      grid-template-columns: repeat(6, 1fr);
      grid-auto-rows: 240px;
      gap: 1.25rem;
    }
    /* Asymmetric layout — feature item large, others varied */
    .portfolio-item--0 { grid-column: span 4; grid-row: span 2; }
    .portfolio-item--0 .portfolio-frame { aspect-ratio: auto; height: 100%; }
    .portfolio-item--1 { grid-column: span 2; grid-row: span 1; }
    .portfolio-item--1 .portfolio-frame { aspect-ratio: auto; height: 100%; }
    .portfolio-item--2 { grid-column: span 2; grid-row: span 1; }
    .portfolio-item--2 .portfolio-frame { aspect-ratio: auto; height: 100%; }
    .portfolio-item--3 { grid-column: span 2; grid-row: span 2; }
    .portfolio-item--3 .portfolio-frame { aspect-ratio: auto; height: 100%; }
    .portfolio-item--4 { grid-column: span 2; grid-row: span 1; }
    .portfolio-item--4 .portfolio-frame { aspect-ratio: auto; height: 100%; }
    .portfolio-item--5 { grid-column: span 2; grid-row: span 1; }
    .portfolio-item--5 .portfolio-frame { aspect-ratio: auto; height: 100%; }

    .portfolio-info {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      padding: 1.25rem 1.4rem;
      color: var(--cream);
      pointer-events: none;
    }
    .portfolio-title {
      color: var(--cream);
      font-family: var(--font-display);
      font-size: 1.3rem;
      text-shadow: 0 2px 12px rgba(0, 0, 0, 0.5);
    }
    .portfolio-loc {
      color: rgba(245, 239, 227, 0.88);
    }
    .portfolio-loc .loc-dot {
      background: var(--marigold);
    }
    .portfolio-cta {
      position: absolute;
      top: 0.85rem;
      right: 0.85rem;
      padding: 0;
      color: var(--cream);
      background: rgba(168, 86, 56, 0.92);
      width: 38px;
      height: 38px;
      border-radius: 50%;
      justify-content: center;
      transform: scale(0);
      transition: transform var(--dur-base) var(--ease-out-soft);
    }
    .portfolio-cta-text { display: none; }
    .portfolio-link:hover .portfolio-cta {
      transform: scale(1);
    }

    .portfolio-bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
    .portfolio-bottom-text {
      max-width: 32ch;
    }
  }
</style>
