---
/**
 * Curved organic SVG section divider — replaces straight horizontal rules.
 * Variants: 'wave', 'arc', 'leaf' — pick whichever matches the section's mood.
 *
 * Renders below a section, fills the next section's background color in the curve
 * so the transition reads as a single continuous shape rather than a hard edge.
 */

interface Props {
  variant?: 'wave' | 'arc' | 'leaf';
  /** Color of the *next* section, which fills the curve. CSS var or hex. */
  fill: string;
  /** Flip vertical orientation (curve points up vs down). */
  flip?: boolean;
  /** Height in rem (default ~5). */
  height?: number;
}

const { variant = 'wave', fill, flip = false, height = 5 } = Astro.props;

const paths: Record<string, string> = {
  wave:
    'M 0 80 C 200 20, 400 100, 600 60 C 800 20, 1000 100, 1200 60 L 1200 120 L 0 120 Z',
  arc:
    'M 0 120 L 0 60 C 300 0, 900 0, 1200 60 L 1200 120 Z',
  leaf:
    'M 0 80 C 150 30, 280 100, 420 60 Q 600 10, 780 60 C 920 100, 1050 30, 1200 80 L 1200 120 L 0 120 Z',
};
---

<div class="section-divider" data-flip={flip} style={`--h: ${height}rem; --fill: ${fill};`}>
  <svg viewBox="0 0 1200 120" preserveAspectRatio="none" aria-hidden="true">
    <path d={paths[variant]} fill="var(--fill)" />
  </svg>
</div>

<style>
  .section-divider {
    position: relative;
    width: 100%;
    height: var(--h, 5rem);
    margin-top: -1px; /* Eliminate sub-pixel gap above */
    line-height: 0;
    pointer-events: none;
  }
  .section-divider svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
  .section-divider[data-flip='true'] {
    transform: scaleY(-1);
  }
</style>
