---
import { serviceAreaCopy, business } from '../content/site';
---

<section id="service-area" class="service-area" aria-labelledby="service-area-h2">
  <div class="container service-area-inner">
    <div class="service-area-text reveal" data-anim="reveal">
      <span class="eyebrow">{serviceAreaCopy.eyebrow.en} · <span lang="es">{serviceAreaCopy.eyebrow.es}</span></span>
      <h2 id="service-area-h2">{serviceAreaCopy.h2.en}</h2>
      <p class="lang-es" lang="es">{serviceAreaCopy.h2.es}</p>
      <ul class="service-cities" role="list">
        {business.serviceArea.cities.map((c) => (
          <li>
            <span class="service-city-mark" aria-hidden="true"></span>
            <span>{c}</span>
          </li>
        ))}
      </ul>
      <p class="service-area-note">
        Outside this list? <a href={business.phone.href} class="service-area-call">Call us</a> — we may still be able to help.
      </p>
    </div>

    <!-- Hand-drawn-feel SVG map. Pure decoration; not interactive. Static image
         deeplinks via the "Open in Maps" link beneath. -->
    <a
      class="service-map reveal"
      data-anim="reveal"
      href={business.address.mapsUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Open Agape Nursery location in Google Maps"
    >
      <svg viewBox="0 0 480 360" class="map-svg" aria-hidden="true">
        <!-- Backdrop -->
        <defs>
          <pattern id="topoLines" x="0" y="0" width="14" height="14" patternUnits="userSpaceOnUse">
            <path d="M 0 7 Q 3.5 5, 7 7 T 14 7" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.25"/>
          </pattern>
          <radialGradient id="centerGlow" cx="50%" cy="55%" r="60%">
            <stop offset="0%" stop-color="#F4A300" stop-opacity="0.3" />
            <stop offset="100%" stop-color="#F4A300" stop-opacity="0" />
          </radialGradient>
        </defs>
        <rect width="480" height="360" fill="#F2EAD7" />
        <rect width="480" height="360" fill="url(#topoLines)" color="#4A5D3A" />
        <rect width="480" height="360" fill="url(#centerGlow)" />

        <!-- Highway 99 abstract path -->
        <path d="M 60 320 Q 180 280, 230 200 T 380 80" fill="none" stroke="#A85638" stroke-width="2.5" stroke-dasharray="6 4" opacity="0.5" />

        <!-- Cities — points + labels -->
        <!-- Visalia -->
        <g transform="translate(380 90)">
          <circle r="6" fill="#4A5D3A" />
          <circle r="14" fill="none" stroke="#4A5D3A" stroke-width="1" opacity="0.4" />
          <text x="14" y="4" font-family="Inter, sans-serif" font-size="13" font-weight="600" fill="#3E2E20">Visalia</text>
        </g>
        <!-- Wasco -->
        <g transform="translate(180 240)">
          <circle r="5" fill="#4A5D3A" />
          <text x="-50" y="4" font-family="Inter, sans-serif" font-size="11" fill="#3E2E20">Wasco</text>
        </g>
        <!-- Shafter -->
        <g transform="translate(220 280)">
          <circle r="5" fill="#4A5D3A" />
          <text x="12" y="4" font-family="Inter, sans-serif" font-size="11" fill="#3E2E20">Shafter</text>
        </g>
        <!-- McFarland -->
        <g transform="translate(280 200)">
          <circle r="5" fill="#4A5D3A" />
          <text x="12" y="4" font-family="Inter, sans-serif" font-size="11" fill="#3E2E20">McFarland</text>
        </g>
        <!-- Bakersfield -->
        <g transform="translate(80 320)">
          <circle r="6" fill="#4A5D3A" />
          <circle r="14" fill="none" stroke="#4A5D3A" stroke-width="1" opacity="0.4" />
          <text x="14" y="4" font-family="Inter, sans-serif" font-size="13" font-weight="600" fill="#3E2E20">Bakersfield</text>
        </g>
        <!-- Delano (us) — terracotta seal -->
        <g transform="translate(240 200)">
          <circle r="22" fill="#A85638" opacity="0.18" />
          <circle r="14" fill="#A85638" opacity="0.4" />
          <circle r="8" fill="#A85638" />
          <circle r="3" fill="#F5EFE3" />
          <text x="0" y="-32" text-anchor="middle" font-family="Fraunces, serif" font-style="italic" font-weight="700" font-size="16" fill="#A85638">Delano</text>
          <text x="0" y="-18" text-anchor="middle" font-family="Inter, sans-serif" font-size="9" fill="#A85638" letter-spacing="2">— US —</text>
        </g>
      </svg>
      <span class="map-cta">
        <span>Open in Maps</span>
        <span aria-hidden="true">↗</span>
      </span>
    </a>
  </div>
</section>

<style>
  .service-area {
    background: linear-gradient(180deg, var(--cream) 0%, #F2EAD7 100%);
  }

  .service-area-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  .service-area-text {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .service-cities {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
    margin-top: 0.85rem;
  }
  .service-cities li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--soil-brown);
    font-weight: 500;
  }
  .service-city-mark {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--terracotta);
    box-shadow: 0 0 0 4px rgba(168, 86, 56, 0.18);
  }

  .service-area-note {
    margin-top: 1rem;
    font-size: 0.95rem;
    color: var(--soil-brown-75);
  }
  .service-area-call {
    color: var(--terracotta);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    font-weight: 500;
  }

  .service-map {
    position: relative;
    display: block;
    border-radius: var(--rad-xl);
    overflow: hidden;
    border: 1px solid var(--soil-brown-15);
    box-shadow: 0 16px 40px var(--shadow-warm);
    aspect-ratio: 4 / 3;
    transition: transform var(--dur-base) var(--ease-out-soft);
  }
  .service-map:hover {
    transform: translateY(-3px);
  }

  .map-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .map-cta {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--cream);
    color: var(--olive-deep);
    padding: 0.5rem 0.95rem;
    border-radius: var(--rad-pill);
    font-size: 0.88rem;
    font-weight: 500;
    box-shadow: 0 4px 12px var(--shadow-warm);
  }

  @media (min-width: 56rem) {
    .service-area-inner {
      grid-template-columns: 1fr 1.1fr;
      gap: 3.5rem;
    }
  }
</style>
