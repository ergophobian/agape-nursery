---
import { hero, business } from '../content/site';

/**
 * Hero v0.2 — full-bleed dramatic California landscape with parallax layers,
 * atmospheric sun glow, and SplitType-driven word reveals.
 *
 * Imagery: drought-tolerant Mediterranean-style California garden, golden hour.
 * Layered SVG botanical foreground (palms, succulents, branches) drift on scroll.
 */

// Hero photo — restored to Kyle's preferred rose-garden / gazebo image (v0.2
// favorite). Readability is now handled by the heavier vignette stack in
// .hero-vignette + the text-shadow + soft backplate behind .hero-h1, so we
// don't need a moodier photo to get clean text contrast.
const HERO_IMAGE =
  'https://images.unsplash.com/photo-1585320806297-9794b3e4eeae?w=2200&q=85&auto=format&fit=crop';

// Tiny LQIP-style placeholder (base64 JPEG of similar tone)
const HERO_LQIP =
  'data:image/svg+xml;utf8,' +
  encodeURIComponent(
    `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 9"><defs><linearGradient id="g" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#A8855B"/><stop offset="0.5" stop-color="#7A6B45"/><stop offset="1" stop-color="#3F4A2C"/></linearGradient></defs><rect width="16" height="9" fill="url(#g)"/></svg>`
  );
---

<section id="top" class="hero" aria-labelledby="hero-h1">
  <!-- ─── Backgrounds: stacked layers ───────────────────────── -->
  <div class="hero-bg" aria-hidden="true">
    <!-- Layer 1: hero photo with darkening gradient -->
    <picture class="hero-photo">
      <img
        src={HERO_IMAGE}
        alt=""
        loading="eager"
        fetchpriority="high"
        decoding="async"
        style={`background-image: url('${HERO_LQIP}'); background-size: cover;`}
      />
    </picture>
    <!-- Layer 2: dark gradient for text contrast -->
    <div class="hero-vignette"></div>
    <!-- Layer 3: warm sun-glow radial -->
    <div class="hero-sun"></div>
    <!-- Layer 4: drifting particles (CSS keyframes, hidden on reduced-motion) -->
    <div class="hero-particles" aria-hidden="true">
      {Array.from({ length: 14 }).map((_, i) => (
        <span class={`particle particle-${i % 4}`} style={`--i: ${i}`}></span>
      ))}
    </div>
    <!-- Layer 5: parallax botanical foreground (SVG silhouettes, hand-drawn feel) -->
    <svg class="hero-leaves hero-leaves-left" viewBox="0 0 220 480" aria-hidden="true" data-parallax="0.06">
      <!-- Palm frond silhouette, lower-left -->
      <g fill="#1F2913" opacity="0.92">
        <path d="M 100 480 C 100 400, 90 320, 70 250 C 50 180, 30 130, 10 100 L 30 90 C 60 130, 80 180, 100 250 C 120 180, 140 130, 170 90 L 190 100 C 170 130, 150 180, 130 250 C 110 320, 100 400, 100 480 Z" />
        <!-- Inner frond rib lines -->
        <path d="M 60 240 C 50 220, 35 200, 20 180" stroke="#2A3818" stroke-width="1.5" fill="none" opacity="0.5" />
        <path d="M 75 200 C 60 180, 40 165, 25 150" stroke="#2A3818" stroke-width="1.5" fill="none" opacity="0.5" />
      </g>
    </svg>

    <svg class="hero-leaves hero-leaves-right" viewBox="0 0 220 480" aria-hidden="true" data-parallax="0.1">
      <!-- Agave / yucca silhouette, lower-right -->
      <g fill="#1F2913" opacity="0.94">
        <path d="M 110 480 L 110 360 C 95 340, 80 320, 60 290 L 75 290 C 90 305, 102 320, 110 332 L 110 290 C 95 270, 78 245, 55 215 L 70 215 C 90 240, 102 258, 110 270 L 110 220 C 95 200, 75 175, 50 145 L 65 140 C 90 165, 105 185, 110 196 L 110 150 C 105 130, 95 105, 80 80 L 95 80 C 105 100, 110 120, 110 132 L 110 90 L 130 90 L 130 132 C 130 120, 135 100, 145 80 L 160 80 C 145 105, 135 130, 130 150 L 130 196 C 135 185, 150 165, 175 140 L 190 145 C 165 175, 145 200, 130 220 L 130 270 C 138 258, 150 240, 170 215 L 185 215 C 162 245, 145 270, 130 290 L 130 332 C 138 320, 150 305, 165 290 L 180 290 C 160 320, 145 340, 130 360 L 130 480 Z" />
      </g>
    </svg>

    <!-- Layer 6: subtle grain (heavier than body grain for atmosphere) -->
    <div class="hero-grain"></div>
  </div>

  <!-- ─── Foreground content ──────────────────────────────── -->
  <div class="hero-inner container">
    <div class="hero-status" data-anim="hero-status">
      <span class="status-pill">
        <span class="pill-dot" aria-hidden="true"></span>
        <span data-lang-en>{hero.status.en}</span><span data-lang-es>{hero.status.es}</span>
      </span>
    </div>

    <h1 id="hero-h1" class="hero-h1" data-split-words>
      <span data-lang-en>
        <span class="hero-line"><span class="hero-word">Growing</span> <span class="hero-word">Delano’s</span></span>
        <span class="hero-line"><span class="hero-word">gardens</span> <span class="hero-word italic-display accent">since</span> <span class="hero-word italic-display accent">1982.</span></span>
      </span>
      <span data-lang-es>
        <span class="hero-line"><span class="hero-word">Cultivando</span></span>
        <span class="hero-line"><span class="hero-word">los jardines de</span></span>
        <span class="hero-line"><span class="hero-word italic-display accent">Delano</span> <span class="hero-word">desde 1982.</span></span>
      </span>
    </h1>

    <p class="hero-lead" data-anim="hero-lead">
      <span data-lang-en>{hero.subhead.en}</span>
      <span data-lang-es>{hero.subhead.es}</span>
    </p>

    <div class="hero-ctas" data-anim="hero-ctas">
      <a href="#booking" class="btn btn-primary hero-primary" data-magnetic>
        <span data-lang-en>{hero.primaryCta.en}</span><span data-lang-es>{hero.primaryCta.es}</span>
        <span class="btn-arrow" aria-hidden="true">→</span>
      </a>
      <a href={business.phone.href} class="hero-secondary" aria-label={`Call ${business.phone.display}`}>
        <span class="hero-secondary-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="14" height="14"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C9.6 21 3 14.4 3 6c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .8-.2 1l-2.3 2.3z" fill="currentColor"/></svg>
        </span>
        <span data-lang-en>{hero.secondaryCta.en}</span><span data-lang-es>{hero.secondaryCta.es}</span>
      </a>
    </div>

    <!-- Hand-drawn signature with year stamp -->
    <div class="hero-trust" data-anim="hero-trust">
      <div class="hero-trust-row">
        <span class="trust-num">{business.yearsInBusiness}</span>
        <div class="trust-text">
          <span class="trust-label-1" data-lang-en>years.</span><span class="trust-label-1" data-lang-es>años.</span>
          <span class="trust-label-2" data-lang-en>One family.</span><span class="trust-label-2" data-lang-es>Una familia.</span>
          <span class="trust-label-3" data-lang-en>Two counties.</span><span class="trust-label-3" data-lang-es>Dos condados.</span>
        </div>
      </div>
    </div>

    <!-- Scroll indicator with botanical accent -->
    <a href="#booking" class="hero-scroll" aria-label="Scroll to booking">
      <span class="scroll-line"></span>
      <span class="scroll-text" data-lang-en>scroll</span>
      <span class="scroll-text" data-lang-es>desliza</span>
    </a>
  </div>

  <!-- Atmospheric "1982" stamp behind everything -->
  <div class="hero-stamp" aria-hidden="true">
    <span>1982</span>
  </div>
</section>

<script>
  /* Hero parallax for botanical layers — subtle scroll-driven translation. */
  const parallaxEls = document.querySelectorAll<HTMLElement>('[data-parallax]');
  if (parallaxEls.length) {
    let ticking = false;
    const update = () => {
      const y = window.scrollY;
      parallaxEls.forEach((el) => {
        const factor = parseFloat(el.dataset.parallax || '0.1');
        el.style.transform = `translate3d(0, ${y * factor}px, 0)`;
      });
      ticking = false;
    };
    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true }
    );
  }

  /* Magnetic button — subtle pull toward cursor on desktop. */
  const magnetic = document.querySelectorAll<HTMLAnchorElement>('[data-magnetic]');
  magnetic.forEach((btn) => {
    let rect: DOMRect;
    btn.addEventListener('mouseenter', () => {
      rect = btn.getBoundingClientRect();
    });
    btn.addEventListener('mousemove', (e) => {
      if (!rect) rect = btn.getBoundingClientRect();
      const x = (e.clientX - rect.left - rect.width / 2) * 0.18;
      const y = (e.clientY - rect.top - rect.height / 2) * 0.18;
      btn.style.transform = `translate(${x}px, ${y}px)`;
    });
    btn.addEventListener('mouseleave', () => {
      btn.style.transform = '';
    });
  });
</script>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: flex-end;
    /* Mobile: keep some breathing room above the fold for the small viewport.
       Use safe-area-inset-top so the H1 never hides under iOS Safari's URL bar. */
    padding-block:
      calc(env(safe-area-inset-top, 0px) + clamp(5rem, 12vh, 8rem))
      clamp(2rem, 5vh, 3.5rem);
    overflow: hidden;
    isolation: isolate;
    color: var(--cream);
  }

  /* ─── Background stack ─── */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
  }

  .hero-photo,
  .hero-photo img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Slow Ken-Burns-style zoom — but only 1.04 over 30s, basically imperceptible.
       This is "alive" not "moving" — different from the flagged Ken Burns hero. */
    animation: heroBreath 32s var(--ease-in-out) infinite alternate;
  }
  @keyframes heroBreath {
    from { transform: scale(1.0); }
    to   { transform: scale(1.05); }
  }

  /* Vignette + color-grade overlay — heavier for guaranteed text contrast.
     The bright sky washed out the H1 in v0.2; this lifts the floor by ~25%. */
  .hero-vignette {
    position: absolute;
    inset: 0;
    background:
      /* Even multiplied wash (darkens highlights, preserves shadow detail) */
      linear-gradient(180deg, rgba(20, 15, 8, 0.45) 0%, rgba(20, 15, 8, 0.55) 50%, rgba(20, 15, 8, 0.92) 100%),
      /* Bottom radial focus to anchor the foreground */
      radial-gradient(ellipse 100% 70% at 50% 110%, rgba(20, 15, 8, 0.5), transparent 70%),
      /* Left-side darken so H1 sits on a calmer canvas */
      linear-gradient(90deg, rgba(20, 15, 8, 0.35) 0%, transparent 60%);
  }

  /* Warm sun-glow */
  .hero-sun {
    position: absolute;
    top: 8%;
    right: -10%;
    width: 70vw;
    height: 70vw;
    max-width: 760px;
    max-height: 760px;
    background:
      radial-gradient(circle, rgba(244, 163, 0, 0.45) 0%, rgba(244, 163, 0, 0.18) 35%, transparent 65%);
    filter: blur(20px);
    pointer-events: none;
    animation: sunDrift 24s var(--ease-in-out) infinite alternate;
  }
  @keyframes sunDrift {
    from { transform: translate(0, 0); }
    to   { transform: translate(-20px, 16px); }
  }

  /* Drifting particles (dust + light motes) */
  .hero-particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .particle {
    position: absolute;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(244, 220, 165, 0.6);
    box-shadow: 0 0 8px rgba(244, 220, 165, 0.5);
    --i: 0;
    top: calc((var(--i) * 47) % 100 * 1%);
    left: calc((var(--i) * 83) % 100 * 1%);
    animation: particleDrift calc(20s + var(--i) * 1.7s) linear infinite;
    opacity: 0;
  }
  .particle-0 { width: 2px; height: 2px; }
  .particle-1 { width: 3px; height: 3px; }
  .particle-2 { width: 4px; height: 4px; opacity: 0.5; }
  .particle-3 { width: 2px; height: 2px; opacity: 0.4; }
  @keyframes particleDrift {
    0%   { transform: translate(0, 0); opacity: 0; }
    10%  { opacity: 1; }
    90%  { opacity: 1; }
    100% { transform: translate(60px, -120vh); opacity: 0; }
  }

  /* Botanical foreground SVGs */
  .hero-leaves {
    position: absolute;
    bottom: -2%;
    height: 70%;
    width: auto;
    max-width: 30%;
    pointer-events: none;
    will-change: transform;
  }
  .hero-leaves-left {
    left: -4%;
    transform: translateX(-10px) rotate(-4deg);
  }
  .hero-leaves-right {
    right: -2%;
    height: 78%;
    max-width: 26%;
    transform: rotate(2deg);
  }

  /* Heavy atmospheric grain */
  .hero-grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: url("data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='160' height='160'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3CfeColorMatrix values='0 0 0 0 0.95 0 0 0 0 0.85 0 0 0 0 0.65 0 0 0 0.55 0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    opacity: 0.16;
    mix-blend-mode: overlay;
  }

  /* ─── Foreground ─── */
  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: clamp(0.85rem, 2vw, 1.35rem);
    align-items: flex-start;
    max-width: 60rem;
    width: 100%;
  }

  .hero-status {
    opacity: 0;
    transform: translateY(8px);
  }
  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.85rem;
    border-radius: var(--rad-pill);
    background: rgba(245, 239, 227, 0.12);
    border: 1px solid rgba(245, 239, 227, 0.2);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: var(--cream);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.04em;
  }
  .pill-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--marigold);
    box-shadow: 0 0 8px var(--marigold);
    animation: pillPulseLight 2.4s var(--ease-out-soft) infinite;
  }
  @keyframes pillPulseLight {
    0%, 100% { box-shadow: 0 0 0 0 rgba(244, 163, 0, 0.6); }
    50%      { box-shadow: 0 0 0 10px rgba(244, 163, 0, 0); }
  }

  /* H1 — heavy-duty text shadow stack + subtle backplate keeps it readable on
     even the brightest photo without needing per-image color tuning. */
  .hero-h1 {
    font-family: var(--font-display);
    font-weight: 800;
    line-height: 0.92;
    letter-spacing: -0.03em;
    color: var(--cream);
    font-size: clamp(2.4rem, 7.5vw, 6.2rem);
    text-shadow:
      0 2px 14px rgba(0, 0, 0, 0.55),
      0 4px 36px rgba(0, 0, 0, 0.45),
      0 0 1px rgba(0, 0, 0, 0.4);
    position: relative;
  }
  /* Subtle backplate using a soft radial — invisible on dark photos, lifts
     text on bright ones. Pseudo-element so it doesn't affect spacing. */
  .hero-h1::before {
    content: '';
    position: absolute;
    inset: -10% -8%;
    background: radial-gradient(ellipse 100% 80% at 30% 50%, rgba(20, 15, 8, 0.35), transparent 70%);
    z-index: -1;
    pointer-events: none;
    filter: blur(20px);
  }
  .hero-line {
    display: block;
    overflow: hidden;
  }
  .hero-word {
    display: inline-block;
    transform: translateY(110%);
    opacity: 0;
    will-change: transform, opacity;
  }
  .hero-word.italic-display.accent {
    color: var(--marigold);
    font-style: italic;
    font-weight: 600;
  }

  .hero-lead {
    font-size: clamp(1rem, 1.2vw + 0.85rem, 1.25rem);
    color: rgba(245, 239, 227, 0.85);
    max-width: 38ch;
    line-height: 1.55;
    opacity: 0;
    transform: translateY(8px);
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
  }

  .hero-ctas {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    align-items: stretch;
    width: 100%;
    max-width: 26rem;
    opacity: 0;
    transform: translateY(8px);
    margin-top: 0.4rem;
  }

  .hero-primary {
    background: var(--terracotta);
    color: var(--cream);
    box-shadow:
      0 8px 28px rgba(168, 86, 56, 0.45),
      inset 0 -2px 0 rgba(0, 0, 0, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.18);
    font-size: 1.02rem;
    padding: 1.1rem 1.6rem;
    transition:
      background var(--dur-fast) var(--ease-out-soft),
      box-shadow var(--dur-fast) var(--ease-out-soft);
    will-change: transform;
  }
  .hero-primary:hover {
    background: #C4683E;
    box-shadow:
      0 14px 40px rgba(168, 86, 56, 0.6),
      inset 0 -2px 0 rgba(0, 0, 0, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.18);
  }

  .hero-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    color: rgba(245, 239, 227, 0.92);
    font-weight: 500;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 5px;
    text-decoration-color: rgba(245, 239, 227, 0.4);
    padding: 0.6rem 0.5rem;
    transition: color var(--dur-fast);
  }
  .hero-secondary:hover {
    color: var(--marigold);
    text-decoration-color: var(--marigold);
  }
  .hero-secondary-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(245, 239, 227, 0.16);
  }

  /* Trust strip */
  .hero-trust {
    margin-top: 1.5rem;
    opacity: 0;
    transform: translateY(8px);
    border-left: 2px solid var(--marigold);
    padding-left: 0.85rem;
  }
  .hero-trust-row {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }
  .trust-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 800;
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    line-height: 1;
    color: var(--marigold);
    letter-spacing: -0.04em;
  }
  .trust-text {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: rgba(245, 239, 227, 0.82);
    line-height: 1.3;
  }
  .trust-label-1 { font-weight: 600; color: var(--cream); font-size: 0.95rem; }

  /* Scroll affordance */
  .hero-scroll {
    position: absolute;
    bottom: -1rem;
    right: 1.5rem;
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: rgba(245, 239, 227, 0.55);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(180deg, transparent, rgba(245, 239, 227, 0.6));
    animation: scrollLine 2.4s var(--ease-in-out) infinite;
  }
  @keyframes scrollLine {
    0%   { transform: scaleY(0.4); transform-origin: top; }
    50%  { transform: scaleY(1); transform-origin: top; }
    51%  { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0.4); transform-origin: bottom; }
  }

  /* Atmospheric "1982" stamp behind */
  .hero-stamp {
    position: absolute;
    right: -4vw;
    bottom: -10vh;
    pointer-events: none;
    z-index: 0;
    user-select: none;
  }
  .hero-stamp span {
    display: block;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 800;
    font-size: clamp(14rem, 32vw, 26rem);
    line-height: 1;
    color: rgba(245, 239, 227, 0.06);
    letter-spacing: -0.06em;
  }

  /* Tablet+ */
  @media (min-width: 48rem) {
    .hero {
      align-items: center;
      padding-block: clamp(7rem, 18vh, 11rem) clamp(3rem, 6vh, 5rem);
    }
    .hero-ctas {
      flex-direction: row;
      align-items: center;
      width: auto;
      max-width: none;
    }
    .hero-secondary {
      justify-content: flex-start;
    }
    .hero-scroll {
      display: flex;
    }
  }
</style>
