---
import { contact, business } from '../content/site';

const CONTACT_IMAGE =
  'https://images.unsplash.com/photo-1469474968028-56623f02e42e?w=1200&q=85&auto=format&fit=crop';

/**
 * Form backend: FormSubmit (formsubmit.co).
 *
 * How it works: the form's POST goes to https://formsubmit.co/<EMAIL>,
 * which forwards every submission as an email to that address. First
 * submission triggers a verification link to the email — once Adolfo
 * clicks it, all future submissions land in his inbox.
 *
 * No signup, no API key, free unlimited.
 *
 * To swap to a real address: change FORM_RECIPIENT to Adolfo's email.
 * To use the privacy-preserving hash mode (hides the email from page
 * source so spam crawlers can't scrape it): generate the hash at
 * https://formsubmit.co/ and paste here.
 */
const FORM_RECIPIENT = business.email; // 'hello@agapenurseryandlandscape.com'
const FORM_ACTION = `https://formsubmit.co/${FORM_RECIPIENT}`;
---

<section id="contact" class="contact" aria-labelledby="contact-h2">
  <div class="contact-pattern" aria-hidden="true"></div>

  <div class="container contact-inner">
    <!-- Heading block — full width on mobile, sits ABOVE both columns -->
    <header class="contact-heading reveal" data-anim="reveal">
      <span class="eyebrow eyebrow-warm">
        <span data-lang-en>{contact.eyebrow.en}</span><span data-lang-es>{contact.eyebrow.es}</span>
      </span>
      <h2 id="contact-h2" class="contact-h2">
        <span data-lang-en>Send a few details. <span class="italic-display accent">We'll be in touch within 24 hours.</span></span>
        <span data-lang-es>Envíe algunos detalles. <span class="italic-display accent">Le contactamos en 24 horas.</span></span>
      </h2>
      <p class="contact-body">
        <span data-lang-en>{contact.body.en}</span><span data-lang-es>{contact.body.es}</span>
      </p>
    </header>

    <!-- Left: supplementary trust + image + contact info (after form on mobile) -->
    <aside class="contact-aside reveal" data-anim="reveal">
      <div class="contact-image">
        <img src={CONTACT_IMAGE} alt="" loading="lazy" decoding="async" width="900" height="650" />
        <div class="contact-image-overlay"></div>
        <div class="contact-image-meta">
          <span class="meta-time italic-display">24h</span>
          <span class="meta-text">
            <span data-lang-en>typical response time</span>
            <span data-lang-es>tiempo típico de respuesta</span>
          </span>
        </div>
      </div>

      <!-- What to expect — sets the async coordination expectation. -->
      <ul class="expect-list" role="list">
        <li>
          <span class="expect-check" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="14" height="14"><path d="M5 12l5 5L21 7" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <span><span data-lang-en>Adolfo replies within 24 hours</span><span data-lang-es>Adolfo responde en 24 horas</span></span>
        </li>
        <li>
          <span class="expect-check" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="14" height="14"><path d="M5 12l5 5L21 7" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <span><span data-lang-en>Free site visit at your schedule</span><span data-lang-es>Visita gratis a su horario</span></span>
        </li>
        <li>
          <span class="expect-check" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="14" height="14"><path d="M5 12l5 5L21 7" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <span><span data-lang-en>Honest, written quote — no pressure</span><span data-lang-es>Presupuesto honesto, sin presión</span></span>
        </li>
        <li>
          <span class="expect-check" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="14" height="14"><path d="M5 12l5 5L21 7" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <span><span data-lang-en>Bilingual — English &amp; Español</span><span data-lang-es>Bilingüe — English &amp; Español</span></span>
        </li>
      </ul>

      <ul class="contact-info" role="list">
        <li>
          <span class="info-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="14" height="14"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C9.6 21 3 14.4 3 6c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .8-.2 1l-2.3 2.3z" fill="currentColor"/></svg>
          </span>
          <a href={business.phone.href}>{business.phone.display}</a>
        </li>
        <li>
          <span class="info-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="14" height="14"><path d="M12 2 C 8 7, 5 11, 5 14 C 5 18, 8 21, 12 21 C 16 21, 19 18, 19 14 C 19 11, 16 7, 12 2 Z" fill="none" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="13" r="2.5" fill="currentColor"/></svg>
          </span>
          <a href={business.address.mapsUrl} target="_blank" rel="noopener noreferrer">{business.address.formatted}</a>
        </li>
        <li>
          <span class="info-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="14" height="14"><circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="M12 7 L12 12 L16 14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" fill="none"/></svg>
          </span>
          <span><span data-lang-en>{business.hours.summary}</span><span data-lang-es>{business.hours.summaryEs}</span></span>
        </li>
      </ul>
    </aside>

    <!-- Right: form. POSTs to FormSubmit which emails Adolfo. -->
    <form
      class="contact-form reveal"
      data-anim="reveal"
      data-contact-form
      action={FORM_ACTION}
      method="POST"
      novalidate
    >
      <!-- FormSubmit config (their special _-prefixed inputs) -->
      <input type="hidden" name="_subject" value="🌿 New site visit request from agapenursery.com" />
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_template" value="table" />
      <input type="hidden" name="_next" value="https://agapenursery.com/?sent=1" />
      <input type="hidden" name="_autoresponse" value="Thanks for reaching out to Agape Nursery & Landscape — Adolfo will get back to you within 24 hours. If urgent, call (661) 778-0602." />

      <!-- Honeypot (FormSubmit's spam check + our own redundancy) -->
      <input type="text" name="_honey" class="hp-field" tabindex="-1" autocomplete="off" aria-hidden="true" />
      <input type="text" name="company" class="hp-field" tabindex="-1" autocomplete="off" aria-hidden="true" />

      <div class="form-grid">
        <div class="form-row">
          <label for="name">
            <span data-lang-en>{contact.form.name.en}</span><span data-lang-es>{contact.form.name.es}</span>
          </label>
          <input id="name" name="name" type="text" required autocomplete="name" placeholder="Maria Lopez" />
        </div>

        <div class="form-row">
          <label for="phone">
            <span data-lang-en>{contact.form.phone.en}</span><span data-lang-es>{contact.form.phone.es}</span>
          </label>
          <input id="phone" name="phone" type="tel" required autocomplete="tel" placeholder="(661) 555-0100" />
        </div>

        <div class="form-row form-row-full">
          <label for="email">
            <span data-lang-en>{contact.form.email.en}</span><span data-lang-es>{contact.form.email.es}</span>
          </label>
          <input id="email" name="email" type="email" autocomplete="email" placeholder="you@example.com" />
        </div>

        <div class="form-row">
          <label for="projectType">
            <span data-lang-en>{contact.form.projectType.en}</span><span data-lang-es>{contact.form.projectType.es}</span>
          </label>
          <select id="projectType" name="projectType" required>
            <option value="">—</option>
            {contact.projectTypes.map((p) => (
              <option value={p.value}>{p.en}</option>
            ))}
          </select>
        </div>

        <div class="form-row">
          <label for="timeline">
            <span data-lang-en>{contact.form.timeline.en}</span><span data-lang-es>{contact.form.timeline.es}</span>
          </label>
          <select id="timeline" name="timeline">
            <option value="">—</option>
            {contact.timelines.map((t) => (
              <option value={t.value}>{t.en}</option>
            ))}
          </select>
        </div>

        <div class="form-row form-row-full">
          <label for="description">
            <span data-lang-en>{contact.form.description.en}</span><span data-lang-es>{contact.form.description.es}</span>
          </label>
          <textarea id="description" name="description" rows="4"
            placeholder="Front yard, backyard, drought-tolerant ideas, anything…"></textarea>
        </div>
      </div>

      <button type="submit" class="btn btn-primary contact-submit" data-submit-button data-magnetic>
        <span data-submit-text>
          <span data-lang-en>{contact.form.submit.en}</span><span data-lang-es>{contact.form.submit.es}</span>
        </span>
        <span class="btn-arrow" aria-hidden="true">→</span>
      </button>

      <p class="contact-disclaimer">
        <span data-lang-en>We use your contact info only to reach you about your inquiry.</span>
        <span data-lang-es>Solo usamos sus datos para contactarle sobre su consulta.</span>
      </p>

      <div class="contact-success" data-success hidden role="status" aria-live="polite">
        <svg viewBox="0 0 24 24" width="40" height="40" aria-hidden="true">
          <circle cx="12" cy="12" r="11" fill="var(--leaf-fresh)" opacity="0.18" />
          <path d="M7 12l4 4 6-7" fill="none" stroke="var(--leaf-fresh)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <p>
          <span data-lang-en>{contact.form.success.en}</span><span data-lang-es>{contact.form.success.es}</span>
        </p>
      </div>
    </form>
  </div>
</section>

<script>
  /**
   * Form submit UX:
   *  - Honeypot fires before the network request (silent reject for bots)
   *  - Real submissions POST to FormSubmit; we use AJAX so we can show
   *    inline success state without a full page redirect (formsubmit
   *    supports JSON responses when content-type is application/json)
   *  - On success: hide form, show the leaf-checkmark success card
   *  - On failure: tell the user to call instead (don't pretend success)
   *
   * We also handle the `?sent=1` URL param — if FormSubmit redirected back
   * here (e.g. JS disabled), we surface the success state immediately.
   */
  const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
  const button = document.querySelector<HTMLButtonElement>('[data-submit-button]');
  const buttonText = document.querySelector<HTMLSpanElement>('[data-submit-text]');
  const success = document.querySelector<HTMLDivElement>('[data-success]');

  const showSuccess = () => {
    if (!form || !success) return;
    success.hidden = false;
    form
      .querySelectorAll<HTMLElement>('.form-row, .contact-submit, .contact-disclaimer')
      .forEach((r) => (r.style.display = 'none'));
    success.scrollIntoView({ behavior: 'smooth', block: 'center' });
  };

  // If the user came back from FormSubmit's redirect with ?sent=1, jump to success
  if (new URLSearchParams(window.location.search).get('sent') === '1') {
    showSuccess();
  }

  if (form && button && buttonText && success) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const honeypot = (form.elements.namedItem('company') as HTMLInputElement)?.value;
      const honey2 = (form.elements.namedItem('_honey') as HTMLInputElement)?.value;
      if (honeypot || honey2) {
        // Silent success for bots — don't tip them off
        showSuccess();
        return;
      }
      button.disabled = true;
      buttonText.textContent = 'Sending…';

      try {
        const data = new FormData(form);
        const resp = await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });
        if (resp.ok) {
          showSuccess();
        } else {
          // FormSubmit returns 200 even on first-submit verification — handle gracefully
          throw new Error(`HTTP ${resp.status}`);
        }
      } catch (err) {
        // Don't fake success on real failures — tell the user to call.
        button.disabled = false;
        buttonText.textContent = 'Try again or call (661) 778-0602';
        button.style.background = '#8C4126';
        console.error('[contact form]', err);
      }
    });
  }
</script>

<style>
  .contact {
    position: relative;
    background: linear-gradient(180deg, var(--cream) 0%, #F2EAD7 100%);
    padding-block: clamp(4rem, 7vw, 7rem);
    overflow: hidden;
  }

  .contact-pattern {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(ellipse 50% 40% at 100% 0%, rgba(74, 93, 58, 0.08), transparent 60%),
      radial-gradient(ellipse 40% 50% at 0% 100%, rgba(168, 86, 56, 0.06), transparent 60%);
    pointer-events: none;
  }

  /* Mobile: heading full width on top, form next, supplementary aside last.
     Desktop: heading spans both cols, then aside + form side by side. */
  .contact-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.75rem;
  }

  .contact-heading {
    order: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    max-width: 38rem;
  }

  /* Aside lives below the form on mobile via order */
  .contact-aside {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    order: 2;
  }
  .contact-form {
    order: 1;
  }

  @media (min-width: 56rem) {
    .contact-inner {
      grid-template-columns: 1fr 1.2fr;
      column-gap: 4rem;
      row-gap: 2.5rem;
    }
    /* Heading spans both columns */
    .contact-heading {
      grid-column: 1 / -1;
      max-width: 50rem;
      margin-bottom: 0.5rem;
    }
    /* Side-by-side, natural source order (aside left, form right) */
    .contact-aside,
    .contact-form {
      order: initial;
    }
  }
  .eyebrow-warm {
    color: var(--terracotta);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 600;
  }
  .contact-h2 {
    /* Tighter mobile baseline (1.55rem ~= 25px) — was 1.85 which made it
       eat 4 lines on iPhone SE. Desktop scales up to 2.6rem as before. */
    font-size: clamp(1.55rem, 3.5vw, 2.6rem);
    line-height: 1.12;
    letter-spacing: -0.018em;
  }
  .contact-h2 .accent {
    color: var(--terracotta);
  }
  .contact-body {
    color: var(--soil-brown-75);
    font-size: 0.98rem;
    line-height: 1.55;
    max-width: 38ch;
  }

  .contact-image {
    position: relative;
    /* Shorter on mobile so it doesn't eat vertical space */
    aspect-ratio: 5 / 3;
    border-radius: var(--rad-xl);
    overflow: hidden;
    border: 1px solid var(--soil-brown-15);
    box-shadow: 0 16px 36px var(--shadow-warm);
  }
  @media (min-width: 56rem) {
    .contact-image {
      aspect-ratio: 16 / 10;
    }
  }
  .contact-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(1.05);
  }
  .contact-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(31, 23, 14, 0.6) 100%);
  }
  .contact-image-meta {
    position: absolute;
    bottom: 1rem;
    left: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--cream);
  }
  .meta-time {
    font-size: 2.4rem;
    font-style: italic;
    font-weight: 800;
    color: var(--marigold);
    letter-spacing: -0.04em;
    line-height: 1;
  }
  .meta-text {
    font-size: 0.78rem;
    color: rgba(245, 239, 227, 0.85);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 500;
    line-height: 1.2;
    max-width: 18ch;
  }

  /* "What to expect" trust list — moved over from the deleted Booking section. */
  .expect-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1rem 1.1rem;
    background: rgba(74, 93, 58, 0.06);
    border: 1px solid rgba(74, 93, 58, 0.14);
    border-radius: var(--rad-lg);
    margin-bottom: 0.5rem;
  }
  .expect-list li {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--soil-brown);
    font-weight: 500;
    font-size: 0.95rem;
  }
  .expect-check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--leaf-fresh);
    color: var(--cream);
    flex-shrink: 0;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .contact-info li {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 0.95rem;
    color: var(--soil-brown);
  }
  .contact-info a:hover { color: var(--terracotta); }
  .info-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(74, 93, 58, 0.1);
    color: var(--olive-deep);
    flex-shrink: 0;
  }

  /* ── Form ── */
  .contact-form {
    background: var(--cream);
    border: 1px solid var(--soil-brown-15);
    border-radius: var(--rad-xl);
    padding: clamp(1.25rem, 3vw, 2.5rem);
    box-shadow: 0 24px 56px var(--shadow-warm-elev);
    align-self: start;
  }

  .hp-field {
    position: absolute;
    left: -10000px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  .form-grid {
    display: grid;
    /* Mobile: stacked single column. iPhone SE was cramming 2 fields side-by-side. */
    grid-template-columns: 1fr;
    gap: 0.85rem;
  }
  @media (min-width: 28rem) {
    .form-grid {
      grid-template-columns: 1fr 1fr;
      gap: 1rem 1.1rem;
    }
  }
  .form-row {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  /* Email + description span both columns at 28rem+ where the grid is 2-col */
  @media (min-width: 28rem) {
    .form-row-full {
      grid-column: 1 / -1;
    }
  }
  .form-row label {
    font-size: 0.78rem;
    color: var(--soil-brown);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .form-row input,
  .form-row select,
  .form-row textarea {
    padding: 0.85rem 1rem;
    border: 1px solid var(--soil-brown-15);
    border-radius: var(--rad-md);
    background: rgba(245, 239, 227, 0.4);
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--soil-brown);
    transition:
      border-color var(--dur-fast),
      box-shadow var(--dur-fast),
      background var(--dur-fast);
  }
  .form-row input::placeholder,
  .form-row textarea::placeholder {
    color: var(--soil-brown-60);
  }
  .form-row input:focus,
  .form-row select:focus,
  .form-row textarea:focus {
    border-color: var(--terracotta);
    box-shadow: 0 0 0 4px rgba(168, 86, 56, 0.15);
    background: var(--cream);
    outline: none;
  }
  .form-row textarea {
    resize: vertical;
    min-height: 110px;
  }

  .contact-submit {
    margin-top: 1.4rem;
    width: 100%;
    background: var(--terracotta);
    box-shadow:
      0 8px 24px rgba(168, 86, 56, 0.4),
      inset 0 -2px 0 rgba(0, 0, 0, 0.18);
    will-change: transform;
  }
  .contact-submit:hover {
    background: var(--terracotta-700);
  }

  .contact-disclaimer {
    margin-top: 0.9rem;
    font-size: 0.78rem;
    color: var(--soil-brown-60);
    text-align: center;
    line-height: 1.5;
  }

  .contact-success {
    text-align: center;
    padding: 2rem 1rem;
    background: rgba(90, 123, 63, 0.08);
    border: 1px solid var(--leaf-fresh);
    border-radius: var(--rad-lg);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: center;
  }
  .contact-success p { max-width: 32ch; line-height: 1.5; }

  @media (min-width: 56rem) {
    .contact-inner {
      grid-template-columns: 1fr 1.2fr;
      gap: 4rem;
    }
  }
</style>
