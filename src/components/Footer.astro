---
import { business, footer, navItems } from '../content/site';
---

<footer class="footer">
  <!-- Big atmospheric image strip -->
  <div class="footer-hero">
    <div class="footer-hero-bg" aria-hidden="true"></div>
    <div class="container footer-cta">
      <span class="eyebrow eyebrow-marigold">
        <span data-lang-en>Ready when you are</span><span data-lang-es>Listo cuando lo esté</span>
      </span>
      <h2 class="footer-cta-h2">
        <span data-lang-en>Your yard is <span class="italic-display accent">already there.</span><br />We just have to plant it.</span>
        <span data-lang-es>Su jardín <span class="italic-display accent">ya está ahí.</span><br />Solo hay que plantarlo.</span>
      </h2>
      <a href="#booking" class="btn btn-primary footer-primary-cta" data-magnetic>
        <span data-lang-en>Book a Free Landscape Consultation</span>
        <span data-lang-es>Reservar Consulta Gratis</span>
        <span class="btn-arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>

  <div class="container footer-inner">
    <div class="footer-grid">
      <div class="footer-col footer-brand">
        <a href="#top" class="footer-brand-link">
          <span class="footer-mark">A</span>
          <span class="footer-name">Agape</span>
        </a>
        <p class="footer-tagline italic-display">Nursery & Landscape Supply.</p>
        <p class="footer-since"><span data-lang-en>Family-owned in</span><span data-lang-es>Familia propietaria en</span> Delano, California. <span data-lang-en>Since</span><span data-lang-es>Desde</span> 1982.</p>
      </div>

      <div class="footer-col">
        <h4 class="footer-h"><span data-lang-en>Visit</span><span data-lang-es>Visite</span></h4>
        <p>
          <a href={business.address.mapsUrl} target="_blank" rel="noopener noreferrer">{business.address.formatted}</a>
        </p>
        <p class="footer-hours">
          <span data-lang-en>{business.hours.summary}</span><span data-lang-es>{business.hours.summaryEs}</span>
        </p>
      </div>

      <div class="footer-col">
        <h4 class="footer-h"><span data-lang-en>Talk</span><span data-lang-es>Llame</span></h4>
        <p>
          <a href={business.phone.href} class="footer-phone">{business.phone.display}</a>
        </p>
        <p class="footer-meta italic-display">"<span data-lang-en>Adolfo answers his phone.</span><span data-lang-es>Adolfo contesta.</span>"</p>
        <p class="footer-meta footer-email">{business.email}</p>
      </div>

      <div class="footer-col">
        <h4 class="footer-h"><span data-lang-en>Find us</span><span data-lang-es>Síganos</span></h4>
        <ul class="footer-socials" role="list">
          <li>
            <a href={business.socials.facebook} target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
                <path d="M13.5 22V13h3l.5-3.5h-3.5V8c0-1 .5-2 2-2h2V3s-1.8-.3-3.5-.3c-3.6 0-5.5 2.2-5.5 5.5V9.5H6v3h3v9.5h4.5z" fill="currentColor"/>
              </svg>
              Facebook
            </a>
          </li>
          <li>
            <a href={business.socials.instagram} target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="5" fill="none" stroke="currentColor" stroke-width="1.6"/>
                <circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.6"/>
                <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"/>
              </svg>
              Instagram
            </a>
          </li>
        </ul>
        <ul class="footer-nav" role="list">
          {navItems.map((item) => (
            <li><a href={`#${item.id}`}><span data-lang-en>{item.en}</span><span data-lang-es>{item.es}</span></a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Big italic typography moment — the quiet brag -->
    <div class="footer-bigword" aria-hidden="true">
      <span class="footer-bigword-text italic-display">Agape</span>
      <span class="footer-bigword-sub">— love, in the garden sense.</span>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">© {new Date().getFullYear()} Agape Nursery & Landscape Supply.</p>
      <p class="footer-built">
        <span data-lang-en>Family-built, family-run since 1982.</span>
        <span data-lang-es>Construido y dirigido por familia desde 1982.</span>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background:
      linear-gradient(180deg, #1F1610 0%, #14100B 100%);
    color: rgba(245, 239, 227, 0.82);
    position: relative;
    overflow: hidden;
  }

  /* Hero strip */
  .footer-hero {
    position: relative;
    padding-block: clamp(4rem, 8vw, 6rem) clamp(3rem, 5vw, 4rem);
    overflow: hidden;
    border-bottom: 1px solid rgba(245, 239, 227, 0.08);
  }
  .footer-hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(244, 163, 0, 0.22), transparent 60%),
      radial-gradient(ellipse 60% 60% at 50% 100%, rgba(168, 86, 56, 0.18), transparent 60%),
      url("data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='200' height='200'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3CfeColorMatrix values='0 0 0 0 0.95 0 0 0 0 0.85 0 0 0 0 0.65 0 0 0 0.18 0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: cover, cover, 200px 200px;
    pointer-events: none;
  }
  .footer-cta {
    position: relative;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }
  .eyebrow-marigold {
    color: var(--marigold);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 600;
  }
  .footer-cta-h2 {
    color: var(--cream);
    font-size: clamp(1.85rem, 4vw, 3rem);
    line-height: 1.06;
    max-width: 18ch;
  }
  .footer-cta-h2 .accent {
    color: var(--marigold);
  }
  .footer-primary-cta {
    margin-top: 0.75rem;
    will-change: transform;
  }

  /* Body grid */
  .footer-inner {
    position: relative;
    padding-block: clamp(3rem, 5vw, 5rem) 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  .footer-h {
    font-family: var(--font-body);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(245, 239, 227, 0.45);
    margin-bottom: 0.85rem;
    font-weight: 600;
  }

  .footer-col p,
  .footer-col li {
    font-size: 0.93rem;
    line-height: 1.55;
    margin-bottom: 0.4rem;
  }
  .footer-col a {
    color: var(--cream);
    transition: color var(--dur-fast);
  }
  .footer-col a:hover { color: var(--marigold); }

  /* Brand */
  .footer-brand-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 0.85rem;
  }
  .footer-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(140deg, #C4683E 0%, var(--terracotta) 100%);
    color: var(--cream);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.4rem;
    box-shadow: 0 4px 16px rgba(168, 86, 56, 0.5);
  }
  .footer-name {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.5rem;
    color: var(--cream);
  }
  .footer-tagline {
    color: var(--marigold);
    font-size: 1.05rem;
    margin-bottom: 0.5rem;
    font-style: italic;
  }
  .footer-since {
    font-size: 0.85rem;
    color: rgba(245, 239, 227, 0.62);
    line-height: 1.55;
  }

  .footer-hours,
  .footer-meta { color: rgba(245, 239, 227, 0.58); font-size: 0.85rem; }
  .footer-email { font-size: 0.82rem; word-break: break-all; }
  .footer-phone {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
  }

  .footer-socials {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    margin-bottom: 1.2rem;
  }
  .footer-socials a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .footer-socials svg { color: var(--marigold); }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    border-top: 1px dashed rgba(245, 239, 227, 0.15);
    padding-top: 1rem;
    font-size: 0.85rem;
  }

  /* Big italic word */
  .footer-bigword {
    text-align: center;
    pointer-events: none;
    user-select: none;
  }
  .footer-bigword-text {
    display: block;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 800;
    font-size: clamp(5rem, 18vw, 14rem);
    line-height: 0.85;
    color: rgba(244, 163, 0, 0.16);
    letter-spacing: -0.05em;
    background: linear-gradient(180deg, rgba(244, 163, 0, 0.32) 0%, rgba(244, 163, 0, 0.04) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .footer-bigword-sub {
    display: block;
    font-style: italic;
    font-family: var(--font-display);
    font-size: clamp(0.9rem, 1.5vw, 1.05rem);
    color: rgba(245, 239, 227, 0.5);
    margin-top: -1rem;
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    align-items: center;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(245, 239, 227, 0.1);
    text-align: center;
    font-size: 0.78rem;
    color: rgba(245, 239, 227, 0.4);
  }
  .footer-built {
    font-style: italic;
  }

  @media (min-width: 48rem) {
    .footer-grid { grid-template-columns: repeat(2, 1fr); }
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }
  @media (min-width: 72rem) {
    .footer-grid { grid-template-columns: 1.4fr 1fr 1fr 1fr; }
  }
</style>
