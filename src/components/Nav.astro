---
import { business, navItems, hero } from '../content/site';
---

<nav class="nav" data-nav aria-label="Primary">
  <div class="nav-inner">
    <a href="#top" class="nav-brand" aria-label={`${business.shortName} home`}>
      <span class="brand-mark">A</span>
      <span class="brand-word">Agape</span>
    </a>

    <ul class="nav-list" role="list">
      {navItems.map((item) => (
        <li>
          <a href={`#${item.id}`} class="nav-link">
            <span>{item.en}</span>
          </a>
        </li>
      ))}
    </ul>

    <div class="nav-cta-wrap">
      <a href={business.phone.href} class="nav-phone" aria-label={`Call ${business.phone.display}`}>
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path
            d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.5.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C9.6 21 3 14.4 3 6c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.5.1.4 0 .8-.2 1l-2.3 2.3z"
            fill="currentColor"
          />
        </svg>
        <span class="nav-phone-text">{business.phone.display}</span>
      </a>
      <button
        class="nav-toggle"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-nav-toggle
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="mobile-menu" aria-hidden="true" data-mobile-menu>
    <ul role="list">
      {navItems.map((item) => (
        <li>
          <a href={`#${item.id}`} class="mobile-link">
            <span class="mobile-link-en">{item.en}</span>
            <span class="mobile-link-es">{item.es}</span>
          </a>
        </li>
      ))}
      <li class="mobile-cta">
        <a href={business.phone.href} class="btn btn-primary btn-block">
          {hero.secondaryCta.en}
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const nav = document.querySelector('[data-nav]') as HTMLElement | null;
  const toggle = document.querySelector('[data-nav-toggle]') as HTMLButtonElement | null;
  const menu = document.querySelector('[data-mobile-menu]') as HTMLElement | null;

  if (nav && toggle && menu) {
    // Sticky-opaque after 200px scroll (PLAN.md §3 IA)
    let lastY = 0;
    let ticking = false;
    const onScroll = () => {
      const y = window.scrollY;
      if (y > 200) nav.classList.add('is-scrolled');
      else nav.classList.remove('is-scrolled');
      lastY = y;
      ticking = false;
    };
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(onScroll);
        ticking = true;
      }
    }, { passive: true });

    // Mobile menu toggle
    let isOpen = false;
    const setOpen = (next: boolean) => {
      isOpen = next;
      toggle.setAttribute('aria-expanded', String(isOpen));
      menu.setAttribute('aria-hidden', String(!isOpen));
      menu.classList.toggle('is-open', isOpen);
      document.body.style.overflow = isOpen ? 'hidden' : '';
    };
    toggle.addEventListener('click', () => setOpen(!isOpen));
    menu.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).matches('a')) setOpen(false);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) setOpen(false);
    });
  }
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-nav);
    padding-block: 0.85rem;
    padding-inline: var(--section-px);
    transition:
      background var(--dur-base) var(--ease-out-soft),
      backdrop-filter var(--dur-base) var(--ease-out-soft),
      border-color var(--dur-base) var(--ease-out-soft);
    border-bottom: 1px solid transparent;
  }
  .nav.is-scrolled {
    background: rgba(245, 239, 227, 0.86);
    backdrop-filter: saturate(140%) blur(14px);
    -webkit-backdrop-filter: saturate(140%) blur(14px);
    border-bottom-color: var(--soil-brown-15);
  }

  .nav-inner {
    max-width: var(--container-wide);
    margin-inline: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .nav-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.4rem;
    color: var(--olive-deep);
    letter-spacing: -0.02em;
  }
  .brand-mark {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--olive-deep);
    color: var(--cream);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.05rem;
    font-weight: 800;
    line-height: 1;
    /* Subtle inner glow gives it a ceramic feel */
    box-shadow: inset 0 -2px 4px rgba(255, 255, 255, 0.18), 0 2px 6px var(--shadow-warm);
  }

  .nav-list {
    display: none;
    align-items: center;
    gap: 1.6rem;
  }
  .nav-link {
    font-size: 0.94rem;
    font-weight: 500;
    color: var(--soil-brown);
    transition: color var(--dur-fast) var(--ease-out-soft);
    position: relative;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -4px;
    height: 1.5px;
    background: var(--terracotta);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--dur-base) var(--ease-out-soft);
  }
  .nav-link:hover {
    color: var(--olive-deep);
  }
  .nav-link:hover::after {
    transform: scaleX(1);
  }

  .nav-cta-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .nav-phone {
    display: none;
    align-items: center;
    gap: 0.5rem;
    color: var(--olive-deep);
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.5rem 0.9rem;
    border-radius: var(--rad-pill);
    transition: background var(--dur-fast) var(--ease-out-soft);
  }
  .nav-phone:hover {
    background: var(--olive-deep-15);
  }
  .nav-phone svg {
    color: var(--terracotta);
  }

  .nav-toggle {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 0.6rem;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    border-radius: var(--rad-md);
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--soil-brown);
    border-radius: 2px;
    transition: transform var(--dur-base) var(--ease-out-soft), opacity var(--dur-fast);
  }
  [aria-expanded='true'] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  [aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }
  [aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-menu {
    position: fixed;
    inset: 0;
    background: var(--cream);
    z-index: calc(var(--z-nav) - 1);
    padding: 6rem 1.5rem 2rem;
    transform: translateX(100%);
    transition: transform var(--dur-base) var(--ease-out-soft);
    overflow-y: auto;
  }
  .mobile-menu.is-open {
    transform: translateX(0);
  }
  .mobile-menu ul {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .mobile-link {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 1rem 1.25rem;
    border-radius: var(--rad-md);
    transition: background var(--dur-fast);
  }
  .mobile-link:hover {
    background: var(--olive-deep-15);
  }
  .mobile-link-en {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--olive-deep);
    line-height: 1.1;
  }
  .mobile-link-es {
    font-size: 0.85rem;
    color: var(--soil-brown-75);
    font-style: italic;
  }
  .mobile-cta {
    margin-top: 1.5rem;
  }

  /* Desktop layout */
  @media (min-width: 64rem) {
    .nav-list {
      display: flex;
    }
    .nav-phone {
      display: inline-flex;
    }
    .nav-toggle {
      display: none;
    }
    .mobile-menu {
      display: none;
    }
  }
</style>
