---
import { inStock, business } from '../content/site';

const updated = new Date(inStock.updated);
const daysOld = Math.floor((Date.now() - updated.getTime()) / 86400000);
const isStale = daysOld > 14;
const formattedDate = updated.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<section id="in-stock" class="in-stock" aria-labelledby="in-stock-h2">
  <div class="container in-stock-inner">
    <header class="in-stock-head reveal" data-anim="reveal">
      <span class="eyebrow">{inStock.eyebrow.en} · <span lang="es">{inStock.eyebrow.es}</span></span>
      <h2 id="in-stock-h2">{inStock.h2.en}</h2>
      {!isStale && (
        <p class="in-stock-updated">
          Updated <time datetime={inStock.updated}>{formattedDate}</time> · we restock weekly
        </p>
      )}
      {isStale && (
        <p class="in-stock-updated stale">
          Inventory changes weekly — call (661) 778-0602 for what’s in today.
        </p>
      )}
    </header>

    {!isStale ? (
      <ul class="stock-grid reveal-stagger" role="list" data-anim="reveal-stagger">
        {inStock.items.map((item) => (
          <li class="stock-item">
            <div class="stock-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="22" height="22">
                <path d="M12 2 L12 22 M5 9c2 4 4 5 7 5 0-3-1-5-3-6-2-1-4 1-4 1z M19 9c-2 4-4 5-7 5 0-3 1-5 3-6 2-1 4 1 4 1z"
                  fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="stock-text">
              <strong class="stock-name">{item.name.en}</strong>
              <span class="lang-es" lang="es">{item.name.es}</span>
              <span class="stock-size">{item.size}</span>
            </div>
            <a href={business.phone.href} class="stock-call" aria-label={`Call to reserve ${item.name.en}`}>
              <span>Call to reserve</span>
              <span aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <div class="stock-fallback reveal" data-anim="reveal">
        <p>We carry annuals, perennials, fruit trees, shade trees, mulch, fertilizer, and more.</p>
        <a href={business.phone.href} class="btn btn-primary">Call for this week’s availability</a>
      </div>
    )}
  </div>
</section>

<style>
  .in-stock {
    background: var(--cream);
    border-top: 1px solid var(--soil-brown-15);
    border-bottom: 1px solid var(--soil-brown-15);
  }

  .in-stock-head {
    max-width: 38rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    margin-bottom: 2rem;
  }
  .in-stock-updated {
    font-size: 0.92rem;
    color: var(--soil-brown-60);
    font-style: italic;
  }
  .in-stock-updated.stale {
    color: var(--terracotta);
    font-weight: 500;
  }

  .stock-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.6rem;
  }

  .stock-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: linear-gradient(180deg, #FAF5E9 0%, #F5EFE3 100%);
    border: 1px solid var(--soil-brown-15);
    border-radius: var(--rad-md);
    transition: transform var(--dur-fast) var(--ease-out-soft),
                border-color var(--dur-fast),
                box-shadow var(--dur-base);
  }
  .stock-item:hover {
    transform: translateX(4px);
    border-color: var(--olive-deep-15);
    box-shadow: 0 6px 16px var(--shadow-warm);
  }

  .stock-icon {
    color: var(--leaf-fresh);
    flex-shrink: 0;
  }

  .stock-text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    flex: 1;
    min-width: 0;
  }
  .stock-name {
    color: var(--olive-deep);
    font-weight: 600;
    font-size: 1.02rem;
  }
  .stock-text .lang-es {
    color: var(--soil-brown-60);
    font-size: 0.85rem;
    margin-top: 0;
  }
  .stock-size {
    font-size: 0.78rem;
    color: var(--soil-brown-60);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 0.15rem;
  }

  .stock-call {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--terracotta);
    font-size: 0.88rem;
    font-weight: 500;
    flex-shrink: 0;
    transition: color var(--dur-fast), gap var(--dur-fast);
    white-space: nowrap;
  }
  .stock-call:hover {
    color: var(--terracotta-700);
    gap: 0.6rem;
  }

  .stock-fallback {
    text-align: center;
    padding: 2rem 1rem;
    background: linear-gradient(180deg, #FAF5E9 0%, #F5EFE3 100%);
    border: 1px solid var(--soil-brown-15);
    border-radius: var(--rad-lg);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  @media (min-width: 48rem) {
    .stock-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 72rem) {
    .stock-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
