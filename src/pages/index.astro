---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import TrustReviews from '../components/TrustReviews.astro';
import Services from '../components/Services.astro';
import Portfolio from '../components/Portfolio.astro';
import About from '../components/About.astro';
import Process from '../components/Process.astro';
import InStock from '../components/InStock.astro';
import ServiceArea from '../components/ServiceArea.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import FloatingCallButton from '../components/FloatingCallButton.astro';
---

<Base>
  <Nav />
  <main id="main">
    <Hero />
    <TrustReviews />
    <Services />
    <Portfolio />
    <About />
    <Process />
    <InStock />
    <ServiceArea />
    <Contact />
  </main>
  <Footer />
  <FloatingCallButton />
</Base>

<script>
  // Single bootstrapper for all motion moments.
  // Loaded via Astro's <script> tag → bundled, defer-loaded after HTML parse.
  import '../scripts/animations.ts';
</script>
